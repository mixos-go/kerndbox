+static int copy_restorer(u32 restorer, unsigned long start, 
+			 unsigned long sr_index, int sr_relative)
+{
+	u32 sr;
+
+	if(sr_relative)
+		restorer += start + sr_index;
+
+	return(copy_to_user((void *) (start + sr_index), &restorer, 
+			    sizeof(restorer)));
+}
+
+static int copy_sc_to_user(void *to, void *fp, struct pt_regs *from, 
+			   int fpstate_size)
+{
+	return(CHOOSE_MODE(ia32_copy_sc_to_user_tt(to, fp,
+						   UPT_SC(&from->regs),
+						   fpstate_size),
+			   ia32_copy_sc_to_user_skas(userspace_pid[0], 
+						     to, fp, &from->regs,
+						     current->thread.cr2,
+						     current->thread.err)));
+}
+
+static int copy_ucontext_to_user(struct ucontext *uc, void *fp, sigset_t *set,
+				 unsigned long sp)
+{
+	int err = 0;
+
+	err |= put_user(current->sas_ss_sp, &uc->uc_stack.ss_sp);
+	err |= put_user(sas_ss_flags(sp), &uc->uc_stack.ss_flags);
+	err |= put_user(current->sas_ss_size, &uc->uc_stack.ss_size);
+	err |= copy_sc_to_user(&uc->uc_mcontext, fp, &current->thread.regs,
+			       si_fpstate_size);
+	err |= copy_to_user(&uc->uc_sigmask, set, sizeof(*set));
+	return(err);
+}
+
+extern volatile int do_go;
+
+int ia32_setup_signal_stack_si(unsigned long stack_top, u32 sig, 
+			       unsigned long handler, u32 restorer,
+			       struct pt_regs *regs, siginfo_t *info, 
+			       sigset_t *mask)
+{
+	u32 start, sip, ucp;
+	void *fp;
+
+	start = stack_top - ia32_signal_frame_si.common.len;
+	sip = start + ia32_signal_frame_si.si_index;
+	ucp = start + ia32_signal_frame_si.uc_index;
+	fp = (void *) (((unsigned long) ucp) + sizeof(struct ucontext));
+
+	if(restorer == 0)
+		panic("setup_signal_stack_si - no restorer");
+
+	if(copy_to_user((void *) (start + ia32_signal_frame_si.common.sig_index), 
+			&sig, sizeof(sig)) ||
+	   ia32_copy_siginfo_to_user((void *) (unsigned long) sip, info) ||
+	   copy_to_user((void *) (start + ia32_signal_frame_si.sip_index), 
+			&sip, sizeof(sip)) ||
+	   copy_ucontext_to_user((void *) ucp, fp, mask, PT_REGS_SP(regs)) ||
+	   copy_to_user((void *) (start + ia32_signal_frame_si.ucp_index), 
+			&ucp, sizeof(ucp)) ||
+	   copy_restorer(restorer, start, ia32_signal_frame_si.common.sr_index,
+			 ia32_signal_frame_si.common.sr_relative))
+		return(1);
+	
+	PT_REGS_IP(regs) = handler;
+	PT_REGS_SP(regs) = start + ia32_signal_frame_si.common.sp_index;
+	return(0);
+}
+
+unsigned long *ia32_sc_sigmask(void *sc_ptr)
+{
+	struct sigcontext_ia32 *sc = sc_ptr;
+
+	return(&sc->oldmask);
+}
+
+int ia32_setup_signal_stack_sc(unsigned long stack_top, u32 sig, 
+			       unsigned long handler, u32 restorer, 
+			       struct pt_regs *regs, compat_sigset_t *mask)
+{
+	struct frame_common *frame = &ia32_signal_frame_sc_sr.common;
+	void *user_sc;
+	int sig_size = (_COMPAT_NSIG_WORDS - 1) * sizeof(unsigned long);
+	unsigned long sigs, sr;
+	unsigned long start = stack_top - frame->len - sig_size;
+
+	user_sc = (void *) (start + ia32_signal_frame_sc_sr.sc_index);
+	if(restorer == 0){
+		frame = &ia32_signal_frame_sc.common;
+		user_sc = (void *) (start + ia32_signal_frame_sc.sc_index);
+		sr = ((unsigned long) frame->data) + frame->sr_index;
+		sr = *((unsigned long *) sr);
+		restorer = sr;
+	}
+
+	sigs = start + frame->len;
+	printk("Copying %d to 0x%p\n", sig, start + frame->sig_index);
+
+	if(copy_to_user((void *) (start + frame->sig_index), &sig, 
+			sizeof(sig)) ||
+	   ({ printk("Copying sc to 0x%p\n", user_sc); 0; }) ||
+	   copy_sc_to_user(user_sc, NULL, regs, sc_fpstate_size) || 
+	   ({ printk("Copying sigmask to 0x%p\n", ia32_sc_sigmask(user_sc)); 0; }) ||
+	   copy_to_user(ia32_sc_sigmask(user_sc), mask, 
+			sizeof(mask->sig[0])) ||
+	   ({ printk("Copying rest of mask to 0x%p\n", sigs); 0; }) ||
+	   copy_to_user((void *) sigs, &mask->sig[1], sig_size) || 
+	   ({ printk("Copying restorer\n"); 0; }) ||
+	   copy_restorer(restorer, start, frame->sr_index, 
+			 frame->sr_relative) ||
+	   ({ printk("Done\n"); 0; }))
+
+		return(1);
+
+	PT_REGS_IP(regs) = handler;
+	PT_REGS_SP(regs) = start + frame->sp_index;
+
+	return(0);
+}
