diff -Naur a/mm/mmfs.c b/mm/mmfs.c
--- a/mm/mmfs.c	1969-12-31 16:00:00.000000000 -0800
+++ b/mm/mmfs.c	2004-04-30 10:24:22.867012038 -0700
@@ -0,0 +1,264 @@
+/* 
+ * Copyright (C) 2002 - 2003 Jeff Dike (jdike@addtoit.com) and
+ * Copyright 2003 PathScale, Inc.
+ * Licensed under the GPL
+ */
+
+#include "linux/stddef.h"
+#include "linux/kernel.h"
+#include "linux/sys.h"
+#include "linux/init.h"
+#include "linux/linkage.h"
+#include "linux/sched.h"
+#include "linux/errno.h"
+#include "linux/mount.h"
+#include "linux/fs.h"
+#include "linux/file.h"
+#include "linux/module.h"
+#include "linux/mm.h"
+#include "linux/mm_fs.h"
+#include "asm/current.h"
+#include "asm/mmu_context.h"
+#include "asm/ptrace.h"
+#include "asm/uaccess.h"
+#include "asm/pgalloc.h"
+#include "asm/unistd.h"
+#include "asm/bitops.h"
+
+static struct file_operations mm_fops;
+static struct vfsmount *mm_mnt;
+
+static int mmfs_delete_dentry(struct dentry *dentry)
+{
+	return 1;
+}
+
+static struct dentry_operations mm_dentry_ops = {
+	d_delete:	mmfs_delete_dentry,
+};
+
+struct mm_struct *mmfs_get_mm(int fd)
+{
+	struct mm_struct *ret = ERR_PTR(-EBADF);
+	struct file *file;
+
+	file = fget(fd);
+	if (file == NULL)
+		goto out;
+
+	ret = ERR_PTR(-EINVAL);
+	if(file->f_op != &mm_fops)
+		goto out_fput;
+
+	ret = file->private_data;
+ out_fput:
+	fput(file);
+ out:
+	return(ret);
+}
+
+static struct inode *get_mm_inode(void)
+{
+	struct inode *inode = new_inode(mm_mnt->mnt_sb);
+
+	if(inode == NULL)
+		return(NULL);
+
+	inode->i_fop = &mm_fops;
+
+	/*
+	 * Mark the inode dirty from the very beginning,
+	 * that way it will never be moved to the dirty
+	 * list because "mark_inode_dirty()" will think
+	 * that it already _is_ on the dirty list.
+	 */
+	inode->i_state = I_DIRTY;
+	inode->i_mode = S_IFIFO | S_IRUSR | S_IWUSR;
+	inode->i_uid = current->fsuid;
+	inode->i_gid = current->fsgid;
+	inode->i_atime = inode->i_mtime = inode->i_ctime = CURRENT_TIME;
+	inode->i_blksize = PAGE_SIZE;
+	return(inode);
+}
+
+asmlinkage long sys_get_mm(void)
+{
+	struct inode *inode;
+	struct dentry *dentry;
+	struct mm_struct *mm;
+	struct file *f;
+	struct qstr str;
+	char name[32];
+	int err = -EBADF;
+	int fd = get_unused_fd();
+
+	if (fd < 0)
+		goto out;
+
+	err = -ENOMEM;
+	f = get_empty_filp();
+	if(f == NULL)
+		goto out_err;
+
+	inode = get_mm_inode();
+	if(inode == NULL)
+		goto out_fput;
+
+	snprintf(name, sizeof(name), "%lu", inode->i_ino);
+	str.name = name;
+	str.len = strlen(name);
+	str.hash = inode->i_ino;
+	dentry = d_alloc(mm_mnt->mnt_sb->s_root, &str);
+	if(dentry == NULL)
+		goto out_iput;
+
+	dentry->d_op = &mm_dentry_ops;
+	d_add(dentry, inode);
+	f->f_vfsmnt = mntget(mm_mnt);
+	f->f_dentry = dget(dentry);
+
+	f->f_pos = 0;
+	f->f_flags = O_RDONLY;
+	f->f_op = &mm_fops;
+	f->f_mode = 0;
+	f->f_version = 0;
+
+	mm = mm_alloc();
+	if(mm == NULL)
+		goto out_dput;
+
+	err = init_new_context(current, mm);
+	if(err)
+		goto out_mmput;
+
+	spin_lock(&mmlist_lock);
+	list_add(&mm->mmlist, &current->mm->mmlist);
+	mmlist_nr++;
+	spin_unlock(&mmlist_lock);
+
+	f->f_op = &mm_fops;
+	f->private_data = mm;
+	fd_install(fd, f);
+ out:
+	return(fd);
+
+ out_mmput:
+	mmput(mm);
+ out_dput:
+	dput(dentry);
+ out_iput:
+	iput(inode);
+ out_fput:
+	fput(f);
+ out_err:
+	put_unused_fd(fd);
+	return(err);
+}
+
+extern long (*sys_call_table[])(struct pt_regs);
+
+unsigned char no_flush_mask[(__NR_syscall_max + 7) / 8 ];
+
+asmlinkage long sys_mm_indirect(int fd, int syscall, struct pt_regs *regs)
+{
+	struct file *file;
+	struct mm_struct *save;
+	struct pt_regs args;
+	int err = -EFAULT;
+	
+	if(copy_from_user(&args, regs, sizeof(args)))
+		goto out;
+
+	err = -EBADF;
+	file = fget(fd);
+	if(file == NULL)
+		goto out;
+
+	save = current->mm;
+	current->mm = file->private_data;
+	if(!test_bit(syscall, (unsigned long *) no_flush_mask))
+		flush_tlb_mm(current->mm);
+
+	err = (*sys_call_table[syscall])(args);
+
+	current->mm = save;
+	if(!test_bit(syscall, (unsigned long *) no_flush_mask))
+		flush_tlb_mm(current->mm);
+
+	fput(file);
+ out:
+	return(err);
+}
+
+static int release_mm(struct inode *inode, struct file *file)
+{
+	struct mm_struct *mm = file->private_data;
+
+	mmput(mm);
+	return(0);
+}
+
+static struct file_operations mm_fops = {
+	.release	= release_mm,
+};
+
+#define MMFS_MAGIC 0xCAFED00D
+
+static struct super_block *mmfs_get_sb(struct file_system_type *fs_type,
+				       int flags, const char *dev_name, 
+				       void *data)
+{
+	return get_sb_pseudo(fs_type, "mm:", NULL, MMFS_MAGIC);
+}
+
+static struct file_system_type mmfs_type = {
+	.name		= "mmfs",
+	.get_sb		= mmfs_get_sb,
+	.kill_sb	= kill_anon_super,
+};
+
+static int no_flush_syscalls[] = { __NR_mmap, /* __NR_mmap2, */ __NR_mprotect, 
+				   __NR_munmap };
+
+static int __init init_mmfs(void)
+{
+	int i, err = register_filesystem(&mmfs_type);
+	if(err)
+		goto out;
+
+	mm_mnt = kern_mount(&mmfs_type);
+	err = PTR_ERR(mm_mnt);
+	if(IS_ERR(mm_mnt))
+		goto out_unregister;
+
+	for(i = 0; i < ARRAY_SIZE(no_flush_syscalls); i++)
+		__set_bit(no_flush_syscalls[i], 
+			  (unsigned long *) no_flush_mask);
+
+	return(0);
+
+ out_unregister:
+	unregister_filesystem(&mmfs_type);
+ out:
+	return(err);
+}
+
+static void __exit exit_mmfs(void)
+{
+	unregister_filesystem(&mmfs_type);
+	mntput(mm_mnt);
+}
+
+module_init(init_mmfs)
+module_exit(exit_mmfs)
+
