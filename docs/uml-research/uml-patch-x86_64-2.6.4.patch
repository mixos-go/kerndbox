+static int ia32_copy_sc_from_user(struct pt_regs *to, void *from, 
+				  int fpstate_size)
+{
+	int ret;
+
+	ret = CHOOSE_MODE(ia32_copy_sc_from_user_tt(UPT_SC(&to->regs), from, 
+					       fpstate_size),
+			  ia32_copy_sc_from_user_skas(&to->regs, from));
