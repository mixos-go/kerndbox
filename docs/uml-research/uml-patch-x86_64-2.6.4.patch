+static int nargs(u32 src, char **dst, char **strings, int *len_out) 
+{ 
+	int cnt, len;
+	u32 val; 
+
+	cnt = 0; 
+	do {
+		int ret = get_user(val, (__u32 *)(u64)src); 
+		if (ret)
+			return ret;
+
+		if (val)
+			len = strnlen_user((void *) (u64) val, -1UL);
+		*len_out += len;
+		if (dst){
+			if (val){
+				ret = copy_from_user(*strings, 
+						     (void *) (u64) val, len);
+				if (ret)
+					return -EFAULT;
+				dst[cnt] = *strings;
+				*strings += len;
+			}
+			else
+				dst[cnt] = NULL;
+		}
+		cnt++;
+		src += 4; 	
+		if (cnt * sizeof(void *) + *len_out >= MAX_ARG_PAGES*PAGE_SIZE)
+			return -E2BIG; 
+	} while(val);
+	if (dst)
+		dst[cnt-1] = 0; 
+	return cnt; 
+} 
+
+asmlinkage long sys32_execve(char *name, u32 argv, u32 envp)
+{ 
+	mm_segment_t oldseg; 
+	char **buf = NULL, *strings, *cur; 
+	int na = 0,ne = 0;
+	int ret, dummy = 0;
+	unsigned sz = 0, string_len = 0; 
+
+	if (argv) {
+	na = nargs(argv, NULL, NULL, &string_len); 
+	if (na < 0) 
+		return -EFAULT; 
+	} 	
+	if (envp) { 
+	ne = nargs(envp, NULL, NULL, &string_len); 
+	if (ne < 0)
+		return -EFAULT; 
+	}
+
+	if (argv || envp) { 
+	sz = (na+ne)*sizeof(void *); 
+	if (sz > PAGE_SIZE) 
+		buf = vmalloc(sz); 
+	else
+		buf = kmalloc(sz, GFP_KERNEL);
+	if (!buf)
+		return -ENOMEM;
+
+	ret = -ENOMEM;
+	if (string_len > PAGE_SIZE)
+		strings = vmalloc(string_len);
+	else
+		strings = kmalloc(string_len, GFP_KERNEL);
+	if (!strings)
+		goto free_vec;
+	}
+
+	cur = strings;
+	if (argv) { 
+	ret = nargs(argv, buf, &cur, &dummy);
+	if (ret < 0)
+		goto free_strings;
+	}
+
+	if (envp) { 
+	ret = nargs(envp, buf + na, &cur, &dummy); 
+	if (ret < 0)
+		goto free_strings; 
+	}
+
+	name = getname(name); 
+	ret = PTR_ERR(name); 
+	if (IS_ERR(name))
+		goto free_strings; 
+
+	oldseg = get_fs(); 
+	set_fs(KERNEL_DS);
+	ret = do_execve(name, argv ? buf : NULL, envp ? buf+na : NULL, 
+			&current->thread.regs);
+	set_fs(oldseg); 
+
+	if (ret == 0)
+		current->ptrace &= ~PT_DTRACE;
+
+	putname(name);
+
+free_strings:
+	if(string_len > PAGE_SIZE)
+		vfree(strings);
+	else 
+		kfree(strings);
+free_vec:
+	if (argv || envp) { 
+	if (sz > PAGE_SIZE)
+		vfree(buf); 
+	else
+	kfree(buf);
+	}
+	return ret; 
+} 
