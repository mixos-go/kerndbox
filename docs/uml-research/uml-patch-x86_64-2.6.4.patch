+int ia32_copy_sc_from_user_tt(void *to_ptr, void *from_ptr, 
+			      int fpstate_size)
+{
+	struct sigcontext *to = to_ptr;
+	struct sigcontext_ia32 *from = from_ptr;
+	struct _fpstate *to_fp;
+	struct _fpstate_ia32 *from_fp;
+	unsigned long sigs;
+	int err = 0;
+
+	err |= __get_user(to->rdi, &from->edi);
+	err |= __get_user(to->rsi, &from->esi);
+	err |= __get_user(to->rbp, &from->ebp);
+	err |= __get_user(to->rsp, &from->esp);
+	err |= __get_user(to->rbx, &from->ebx);
+	err |= __get_user(to->rdx, &from->edx);
+	err |= __get_user(to->rcx, &from->ecx);
+	err |= __get_user(to->rax, &from->eax);
+	err |= __get_user(to->cs, &from->cs);
+#if 0
+	err |= __get_user(to->ss, &from->ss);
+#endif
+	err |= __get_user(to->trapno, &from->trapno);
+	err |= __get_user(to->err, &from->err);
+	err |= __get_user(to->rip, &from->eip);
+	err |= __get_user(to->eflags, &from->eflags);
+	err |= __get_user(to->rsp, &from->esp_at_signal);
+	err |= __get_user(to->cr2, &from->cr2);
+
+	to_fp = to->fpstate;
+	from_fp = from->fpstate;
+	sigs = to->oldmask;
+	to->oldmask = sigs;
+	if(to_fp != NULL){
+		err |= copy_from_user_proc(&to->fpstate, &to_fp,
+					      sizeof(to->fpstate));
+		err |= copy_from_user_proc(to_fp, from_fp, fpstate_size);
+	}
+	return(err);
+}
