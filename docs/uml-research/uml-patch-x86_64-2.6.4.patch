+int ia32_copy_sc_to_user_tt(void *to_ptr, void *fp, void *from_ptr, 
+			    int fpstate_size)
+{
+	struct sigcontext *from = from_ptr;
+	struct sigcontext_ia32 *to = to_ptr;
+	struct _fpstate *from_fp;
+	struct _fpstate_ia32 *to_fp;
+	int err = 0;
+
+	err |= __put_user((u32)from->rdi, &to->edi);
+	err |= __put_user((u32)from->rsi, &to->esi);
+	err |= __put_user((u32)from->rbp, &to->ebp);
+	err |= __put_user((u32)from->rsp, &to->esp);
+	err |= __put_user((u32)from->rbx, &to->ebx);
+	err |= __put_user((u32)from->rdx, &to->edx);
+	err |= __put_user((u32)from->rcx, &to->ecx);
+	err |= __put_user((u32)from->rax, &to->eax);
+	err |= __put_user((u32)from->cs, &to->cs);
+#if 0
+	err |= __put_user((u32)from->ss, &to->ss);
+#endif
+	err |= __put_user(from->trapno, &to->trapno);
+	err |= __put_user(from->err, &to->err);
+	err |= __put_user((u32)from->rip, &to->eip);
+	err |= __put_user((u32)from->eflags, &to->eflags);
+	err |= __put_user((u32)from->rsp, &to->esp_at_signal);
+	err |= __put_user((u32) from->cr2, &to->cr2);
+
+	to_fp = (struct _fpstate_ia32 *) 
+		(fp ? (unsigned long) fp : ((unsigned long) to + sizeof(*to)));
+	from_fp = from->fpstate;
+	if(from_fp != NULL){
+		err |= copy_to_user_proc(&to->fpstate, &to_fp,
+					  sizeof(to->fpstate));
+		err |= copy_to_user_proc(to_fp, from_fp, fpstate_size);
+	}
+	return(err);
+}
