+asmlinkage long
+sys32_stat64(char * filename, struct stat64 *statbuf)
+{
+	char *name;
+	int ret;
+	struct stat s;
+	mm_segment_t old_fs = get_fs();
+	
+	name = getname(filename);
+	if (IS_ERR(name))
+		return PTR_ERR(name);
+	set_fs (KERNEL_DS);
+	ret = sys_newstat(name, &s);
+	set_fs (old_fs);
+	putname(name);
+	if (putstat64 (statbuf, &s))
+		return -EFAULT;
+	return ret;
+}
