config UML_ARM64
	def_bool y

config 64BIT
	def_bool y

config MODULES_USE_ELF_RELA
	def_bool y

config 3_LEVEL_PGTABLES
	def_bool y
	help
	  arm64 UML uses a 39-bit VA (512 GB) user address space with
	  3-level page tables (4K pages, PGD/PUD/PMD).  This mirrors
	  the default arm64 kernel configuration and matches TASK_SIZE.

# arm64 always uses rt_sigframe (no classic sigframe)
config ARCH_HAS_SC_SIGNALS
	def_bool n

# arm64 does not reuse host vsyscall area
config ARCH_REUSE_HOST_VSYSCALL_AREA
	def_bool n

config GENERIC_HWEIGHT
	def_bool y

config ARCH_WANT_DEFAULT_TOPDOWN_MMAP_LAYOUT
	def_bool y

# arm64 always uses generic checksum (no hardware-specific csum asm in UML)
config GENERIC_CSUM
	def_bool y

config GENERIC_CALIBRATE_DELAY
	def_bool y

# ── arm64 hardware features NOT applicable to UML ─────────────────────────
#
# These would pull in arch/arm64/lib/ or hardware-specific code that cannot
# run in UML (userspace process). Explicitly disabled here.

# No persistent memory / DC CVAP instructions in UML
# (would require ARCH_HAS_UACCESS_FLUSHCACHE + arch/arm64/lib/uaccess_flushcache.c)
config ARM64_PMEM
	def_bool n

# No hardware memory tagging (MTE) in UML
config ARM64_MTE
	def_bool n

# No NEON/SVE in UML kernel context
# (UML runs as a userspace process; host kernel controls FP state)
config KERNEL_MODE_NEON
	def_bool n

# No hardware RNG (RNDR instruction) in UML
config ARCH_RANDOM
	def_bool n

# No PAC (Pointer Authentication) in UML kernel
# (host kernel handles PAC for the UML process itself)
config ARM64_PTR_AUTH
	def_bool n

config ARM64_PTR_AUTH_KERNEL
	def_bool n

# No Branch Target Identification in UML
config ARM64_BTI_KERNEL
	def_bool n
