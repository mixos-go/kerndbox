From: DevBox UML arm64 Port
Subject: [PATCH] um/kernel/skas/syscall.c: save/restore x0-x5 around SET_SYSCALL_RETURN on arm64

On arm64, x0 is both arg1 and retval. PT_REGS_SET_SYSCALL_RETURN(-ENOSYS)
clobbers x0 before EXECUTE_SYSCALL reads UPT_SYSCALL_ARG1. Save and restore.

--- a/arch/um/kernel/skas/syscall.c
+++ b/arch/um/kernel/skas/syscall.c
@@ -21,7 +21,26 @@
 
 	/* Initialize the syscall number and default return value. */
 	UPT_SYSCALL_NR(r) = PT_SYSCALL_NR(r->gp);
+#ifdef __aarch64__
+	/*
+	 * On arm64 x0 is both the first syscall argument and the return value
+	 * register. PT_REGS_SET_SYSCALL_RETURN writes -ENOSYS into gp[0] which
+	 * would clobber arg1. Save args before and restore after.
+	 */
+	unsigned long __saved_args[6] = {
+		r->gp[0], r->gp[1], r->gp[2],
+		r->gp[3], r->gp[4], r->gp[5],
+	};
 	PT_REGS_SET_SYSCALL_RETURN(regs, -ENOSYS);
+	r->gp[0] = __saved_args[0];
+	r->gp[1] = __saved_args[1];
+	r->gp[2] = __saved_args[2];
+	r->gp[3] = __saved_args[3];
+	r->gp[4] = __saved_args[4];
+	r->gp[5] = __saved_args[5];
+#else
+	PT_REGS_SET_SYSCALL_RETURN(regs, -ENOSYS);
+#endif
 
 	if (syscall_trace_enter(regs))
 		goto out;
