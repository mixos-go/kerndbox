From: DevBox UML arm64 Port
Subject: [PATCH] scripts: generate_rust_target: add UML arm64 target

arm64 bare-metal uses the builtin rustc aarch64-unknown-none target.
However, UML arm64 runs as a Linux userspace process, so it needs a
custom target.json similar to how x86_64 UML generates one.

When ARCH=um SUBARCH=arm64, auto.conf sets CONFIG_UML_ARM64=y but NOT
CONFIG_ARM64 (SRCARCH=um, not arm64). So we must check UML_ARM64, not
ARM64, to detect this case.

--- a/scripts/generate_rust_target.rs
+++ b/scripts/generate_rust_target.rs
@@ -186,6 +186,25 @@
     // `llvm-target`s are taken from `scripts/Makefile.clang`.
     if cfg.has("ARM64") {
         panic!("arm64 uses the builtin rustc aarch64-unknown-none target");
+    } else if cfg.has("UML_ARM64") {
+        // UML arm64: runs as a Linux userspace process on an arm64 host.
+        // Cannot use aarch64-unknown-none (bare-metal); needs a Linux target.
+        // Note: ARCH=um SUBARCH=arm64 sets CONFIG_UML_ARM64, not CONFIG_ARM64.
+        ts.push("arch", "aarch64");
+        ts.push(
+            "data-layout",
+            "e-m:e-i8:8:32-i16:16:32-i64:64-i128:128-n32:64-S128",
+        );
+        // Disable NEON/SVE: UML kernel code runs in a Linux process context.
+        // The host kernel owns FP/SIMD state; using NEON here would corrupt it.
+        let features = "-neon,-sve,-sve2".to_string();
+        ts.push("features", features);
+        ts.push("llvm-target", "aarch64-linux-gnu");
+        if cfg.rustc_version_atleast(1, 91, 0) {
+            ts.push("target-pointer-width", 64);
+        } else {
+            ts.push("target-pointer-width", "64");
+        }
     } else if cfg.has("RISCV") {
         if cfg.has("64BIT") {
             panic!("64-bit RISC-V uses the builtin rustc riscv64-unknown-none-elf target");
