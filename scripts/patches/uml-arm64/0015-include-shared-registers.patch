From: DevBox UML arm64 Port
Subject: [PATCH] um: registers: guard x86-only i387 declarations with CONFIG_X86

save_i387/restore_i387/save_fp/restore_fp/save_fpx/restore_fpx are
x86-specific interfaces that use the ptrace i387 ABI. Guard them with
CONFIG_X86 so arm64 UML does not try to compile or link them.

get_safe_registers, get_fp_registers, put_fp_registers are arch-generic
interfaces — each arch provides its own implementation. Leave them
unguarded so arm64 can provide and declare its own versions.

--- a/arch/um/include/shared/registers.h
+++ b/arch/um/include/shared/registers.h
@@ -8,10 +8,16 @@
 
 #include <sysdep/ptrace.h>
 
+/* x86-only: ptrace i387 / fpx / fpstate interfaces */
+#ifdef CONFIG_X86
 extern int save_i387_registers(int pid, unsigned long *fp_regs);
 extern int restore_i387_registers(int pid, unsigned long *fp_regs);
 extern int save_fp_registers(int pid, unsigned long *fp_regs);
 extern int restore_fp_registers(int pid, unsigned long *fp_regs);
 extern int save_fpx_registers(int pid, unsigned long *fp_regs);
 extern int restore_fpx_registers(int pid, unsigned long *fp_regs);
+#endif /* CONFIG_X86 */
+
+/* Arch-generic: each arch provides its own implementation */
 extern int init_pid_registers(int pid);
 extern void get_safe_registers(unsigned long *regs, unsigned long *fp_regs);
 extern int get_fp_registers(int pid, unsigned long *regs);
