From: DevBox UML arm64 Port
Subject: [PATCH 9/13] um/os-Linux/registers.c: arm64 compat for init_pid_registers

--- a/arch/um/os-Linux/registers.c
+++ b/arch/um/os-Linux/registers.c
@@ -18,11 +18,19 @@
 
 int init_pid_registers(int pid)
 {
-	int err;
+	int err = 0;
 
+#ifdef __aarch64__
+	extern int ptrace_getregs(long pid, unsigned long *regs_out);
+	extern int ptrace_setregs(long pid, unsigned long *regs_in);
+	err = ptrace_getregs(pid, exec_regs);
+	if (err < 0)
+		return err;
+#else
 	err = ptrace(PTRACE_GETREGS, pid, 0, exec_regs);
 	if (err < 0)
 		return -errno;
+#endif
 
 	arch_init_registers(pid);
 	get_fp_registers(pid, exec_fp_regs);

--- a/arch/um/kernel/process.c
+++ b/arch/um/kernel/process.c
@@ -292,8 +292,16 @@ int copy_thread(struct task_struct *p, const struct kernel_clone_args *args)

 int elf_core_copy_task_fpregs(struct task_struct *t, elf_fpregset_t *fpu)
 {
+#ifdef CONFIG_X86
 	int cpu = current_thread_info()->cpu;

 	return save_i387_registers(userspace_pid[cpu], (unsigned long *) fpu) == 0;
+#else
+	/* arm64 UML: get FPSIMD state via PTRACE_GETREGSET/NT_PRFPREG */
+	int cpu = current_thread_info()->cpu;
+	int pid = userspace_pid[cpu];
+
+	return get_fp_registers(pid, (unsigned long *) fpu) == 0;
+#endif
 }
