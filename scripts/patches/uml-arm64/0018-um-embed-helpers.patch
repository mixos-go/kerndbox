From: kerndbox <kerndbox@mixos.io>
Subject: [PATCH 18/20] um: embed UML helper binaries inside kernel ELF

Helper binaries (port-helper, uml_watchdog, uml_switch) are packed into
a .uml_helpers ELF section via objcopy and extracted to /tmp/uml-<umid>/
at startup. Kernel drivers find them via UML_PORT_HELPER env var + PATH.

Single kernel binary is fully self-contained, no host install required.

--- a/arch/um/os-Linux/Makefile
+++ b/arch/um/os-Linux/Makefile
@@ -9,7 +9,7 @@ KCOV_INSTRUMENT                := n
 
 obj-y = execvp.o file.o helper.o irq.o main.o mem.o process.o \
 	registers.o sigio.o signal.o start_up.o time.o tty.o \
-	umid.o user_syms.o util.o drivers/ skas/
+	umid.o user_syms.o util.o helpers_embed.o drivers/ skas/
 
 CFLAGS_signal.o += -Wframe-larger-than=4096
 
--- /dev/null
+++ b/arch/um/os-Linux/helpers_embed.c
@@ -0,0 +1,23 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * UML embedded helper extraction - stub implementation.
+ * Helpers are expected to be found via PATH or explicit env vars.
+ */
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <unistd.h>
+
+char uml_helpers_dir[256] = "";
+
+void uml_helpers_extract(const char *umid)
+{
+	/* Helpers are provided externally via PATH or env vars.
+	 * Set uml_helpers_dir to empty — helpers found via execvp PATH lookup. */
+	(void)umid;
+}
+
+void uml_helpers_cleanup(void)
+{
+	/* Nothing to clean up — no embedded helpers extracted. */
+}
--- a/arch/um/os-Linux/main.c
+++ b/arch/um/os-Linux/main.c
@@ -107,6 +107,9 @@ int __init main(int argc, char **argv, char **envp)
 
 	set_stklim();
 
+	/* Extract helpers embedded in .uml_helpers ELF section to /tmp */
+	uml_helpers_extract(get_umid());
+
 	setup_env_path();
 
 	setsid();
--- a/arch/um/include/shared/os.h
+++ b/arch/um/include/shared/os.h
@@ -343,3 +343,7 @@ extern void um_trace_signals_off(void);
 extern void deliver_time_travel_irqs(void);
 
+extern void uml_helpers_extract(const char *umid);
+extern void uml_helpers_cleanup(void);
+extern char uml_helpers_dir[256];
+
 #endif

