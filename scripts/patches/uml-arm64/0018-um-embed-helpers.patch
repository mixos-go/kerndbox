From: kerndbox <kerndbox@mixos.io>
Subject: [PATCH 18/20] um: embed UML helper binaries inside kernel ELF

Helper binaries (port-helper, uml_watchdog, uml_switch) are packed into
a .uml_helpers ELF section via objcopy and extracted to /tmp/uml-<umid>/
at startup. Kernel drivers find them via UML_PORT_HELPER env var + PATH.

Single kernel binary is fully self-contained, no host install required.

--- a/arch/um/os-Linux/Makefile
+++ b/arch/um/os-Linux/Makefile
@@ -9,7 +9,7 @@ KCOV_INSTRUMENT                := n
 
 obj-y = execvp.o file.o helper.o irq.o main.o mem.o process.o \
 	registers.o sigio.o signal.o start_up.o time.o tty.o \
-	umid.o user_syms.o util.o drivers/ skas/
+	umid.o user_syms.o util.o helpers_embed.o drivers/ skas/
 
 CFLAGS_signal.o += -Wframe-larger-than=4096
 
--- /dev/null
+++ b/arch/um/os-Linux/helpers_embed.c
@@ -0,0 +1,100 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * UML embedded helper extraction.
+ *
+ * At startup, extract helpers from the .uml_helpers ELF section to
+ * /tmp/uml-<umid>/ and configure PATH + env vars so kernel drivers
+ * can exec() them via run_helper().
+ *
+ * Bundle format (UMLH, little-endian):
+ *   u8[4]  magic "UMLH"
+ *   u32    count
+ *   entry[]: name\0 + u32 compressed_size + gzip data
+ */
+#define _GNU_SOURCE
+#include <linux/types.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <unistd.h>
+#include <fcntl.h>
+#include <sys/stat.h>
+#include <zlib.h>
+#include <os.h>
+
+/* Linker-generated symbols bracketing the .uml_helpers section.
+ * Section name ".uml_helpers" → linker symbols __start__uml_helpers /
+ * __stop__uml_helpers (dot replaced by underscore in symbol names). */
+extern const char __start__uml_helpers[] __attribute__((weak));
+extern const char __stop__uml_helpers[]  __attribute__((weak));
+
+char uml_helpers_dir[256] = "";
+
+static __u32 rd_le32(const unsigned char *p)
+{
+	return (__u32)p[0] | ((__u32)p[1]<<8) |
+	       ((__u32)p[2]<<16) | ((__u32)p[3]<<24);
+}
+
+void uml_helpers_extract(const char *umid)
+{
+	const unsigned char *p, *end;
+	__u32 count, i;
+	char path[512];
+	int fd;
+
+	if (!__start__uml_helpers || !__stop__uml_helpers ||
+	    __stop__uml_helpers <= __start__uml_helpers)
+		return;
+
+	p   = (const unsigned char *)__start__uml_helpers;
+	end = (const unsigned char *)__stop__uml_helpers;
+
+	if (end - p < 8 || memcmp(p, "UMLH", 4) != 0)
+		return;
+
+	count = rd_le32(p + 4);
+	p += 8;
+
+	snprintf(uml_helpers_dir, sizeof(uml_helpers_dir), "/tmp/uml-%s", umid);
+	mkdir(uml_helpers_dir, 0700);
+
+	for (i = 0; i < count && p < end; i++) {
+		const char *name = (const char *)p;
+		size_t namelen = strlen(name);
+		__u32 csize;
+		uLong dstlen;
+		Bytef *dst;
+
+		p += namelen + 1;
+		if (p + 4 > end) break;
+		csize = rd_le32(p); p += 4;
+		if (p + csize > end) break;
+
+		dstlen = 8 * 1024 * 1024;
+		dst = malloc(dstlen);
+		if (!dst) { p += csize; continue; }
+
+		if (uncompress(dst, &dstlen, p, csize) == Z_OK) {
+			snprintf(path, sizeof(path), "%s/%s",
+				 uml_helpers_dir, name);
+			fd = open(path, O_WRONLY | O_CREAT | O_TRUNC, 0755);
+			if (fd >= 0) {
+				write(fd, dst, dstlen);
+				close(fd);
+			}
+		}
+		free(dst);
+		p += csize;
+	}
+
+	/* Set env vars for kernel drivers */
+	snprintf(path, sizeof(path), "%s/port-helper", uml_helpers_dir);
+	if (access(path, X_OK) == 0)
+		setenv("UML_PORT_HELPER", path, 1);
+
+	snprintf(path, sizeof(path), "%s/uml_watchdog", uml_helpers_dir);
+	if (access(path, X_OK) == 0)
+		setenv("UML_WATCHDOG", path, 1);
+
+	/* Prepend helpers dir to PATH so run_helper() / execvp() finds them */
+	{
+		const char *old = getenv("PATH");
+		char newp[512];
+		snprintf(newp, sizeof(newp), "%s:%s", uml_helpers_dir,
+			 old ? old : "/usr/local/bin:/usr/bin:/bin");
+		setenv("PATH", newp, 1);
+	}
+}
+
+void uml_helpers_cleanup(void)
+{
+	char cmd[320];
+	if (uml_helpers_dir[0]) {
+		snprintf(cmd, sizeof(cmd), "rm -rf %s", uml_helpers_dir);
+		system(cmd);
+	}
+}
--- a/arch/um/os-Linux/main.c
+++ b/arch/um/os-Linux/main.c
@@ -107,6 +107,9 @@ int __init main(int argc, char **argv, char **envp)
 
 	set_stklim();
 
+	/* Extract helpers embedded in .uml_helpers ELF section to /tmp */
+	uml_helpers_extract(get_umid());
+
 	setup_env_path();
 
 	setsid();
--- a/arch/um/include/shared/os.h
+++ b/arch/um/include/shared/os.h
@@ -343,3 +343,7 @@ extern void um_trace_signals_off(void);
 extern void deliver_time_travel_irqs(void);
 
+extern void uml_helpers_extract(const char *umid);
+extern void uml_helpers_cleanup(void);
+extern char uml_helpers_dir[256];
+
 #endif

