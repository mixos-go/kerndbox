From: kerndbox <kerndbox@mixos.io>
Subject: [PATCH] um: add helpers_embed stub to os-Linux

Add helpers_embed.c as userspace object (USER_OBJS) so it compiles
with USER_CFLAGS — gives access to libc stdio.h/stdlib.h.
Without USER_OBJS, kernel -nostdinc flags block stdio.h.

helpers_embed.c is a no-op stub; copied to SRC_DIR by build script.

--- a/arch/um/os-Linux/Makefile
+++ b/arch/um/os-Linux/Makefile
@@ -8,7 +8,7 @@ KCOV_INSTRUMENT                := n
 
 obj-y = execvp.o file.o helper.o irq.o main.o mem.o process.o \
 	registers.o sigio.o signal.o start_up.o time.o tty.o \
-	umid.o user_syms.o util.o drivers/ skas/
+	umid.o user_syms.o util.o helpers_embed.o drivers/ skas/
 
 CFLAGS_signal.o += -Wframe-larger-than=4096
 
@@ -16,6 +16,6 @@ obj-$(CONFIG_ARCH_REUSE_HOST_VSYSCALL_AREA) += elf_aux.o
 
 USER_OBJS := $(user-objs-y) elf_aux.o execvp.o file.o helper.o irq.o \
 	main.o mem.o process.o registers.o sigio.o signal.o start_up.o time.o \
-	tty.o umid.o util.o
+	tty.o umid.o util.o helpers_embed.o
 
 include $(srctree)/arch/um/scripts/Makefile.rules
--- a/arch/um/os-Linux/main.c
+++ b/arch/um/os-Linux/main.c
@@ -111,6 +111,8 @@ int __init main(int argc, char **argv, char **envp)
 
 	set_stklim();
 
+	uml_helpers_extract(get_umid());
+
 	setup_env_path();
 
 	setsid();
--- a/arch/um/include/shared/os.h
+++ b/arch/um/include/shared/os.h
@@ -343,3 +343,7 @@ extern void um_trace_signals_off(void);
 extern void deliver_time_travel_irqs(void);
 
+extern void uml_helpers_extract(const char *umid);
+extern void uml_helpers_cleanup(void);
+extern char uml_helpers_dir[256];
+
 #endif
