Subject: [PATCH] um: skas/process.c: arm64 syscall interception

Two-stop syscall interception for arm64 UML:
1. syscall-entry stop: save args (x0-x5, x8), neutralize via PTRACE_SET_SYSCALL
   or PTRACE_SETREGSET fallback (for VM environments where PTRACE_SET_SYSCALL
   returns EIO, e.g. GitHub Actions arm64 / AWS Graviton)
2. syscall-exit stop: restore NR+args, call handle_trap()

--- a/arch/um/os-Linux/skas/process.c
+++ b/arch/um/os-Linux/skas/process.c
@@ -21,6 +21,15 @@
 #include <ptrace_user.h>
 #include <registers.h>
 #include <skas.h>
+#ifdef __aarch64__
+#include <sys/uio.h>
+#include <elf.h>
+#include <errno.h>
+#ifndef PTRACE_SET_SYSCALL
+#define PTRACE_SET_SYSCALL 23
+#endif
+extern int sysemu_supported;
+#endif
 #include <sysdep/stub.h>
 #include <linux/threads.h>
 #include <timetravel.h>
@@ -336,6 +345,40 @@
 	return err;
 }
 
+#ifdef __aarch64__
+static bool arm64_at_entry;
+static unsigned long arm64_saved_nr;
+static unsigned long arm64_saved_args[6];
+
+static void arm64_neutralize_syscall(int pid)
+{
+	if (ptrace(PTRACE_SET_SYSCALL, pid, 0,
+		   (void *)(unsigned long)__NR_getpid) == 0)
+		return;
+
+	/* Fallback: write x8 = __NR_getpid via PTRACE_SETREGSET.
+	 * Same effect as PTRACE_SET_SYSCALL on environments where the
+	 * latter returns EIO (e.g. GitHub Actions arm64/AWS Graviton). */
+	{
+		unsigned long long regs[34];
+		struct iovec iov = { regs, sizeof(regs) };
+		if (ptrace(PTRACE_GETREGSET, pid, (void *)(long)NT_PRSTATUS, &iov) < 0) {
+			printk(UM_KERN_ERR "%s: PTRACE_GETREGSET failed, errno=%d\n",
+			       __func__, errno);
+			fatal_sigsegv();
+		}
+		regs[8] = __NR_getpid;
+		iov.iov_len = sizeof(regs);
+		if (ptrace(PTRACE_SETREGSET, pid, (void *)(long)NT_PRSTATUS, &iov) < 0) {
+			printk(UM_KERN_ERR "%s: PTRACE_SETREGSET failed, errno=%d\n",
+			       __func__, errno);
+			fatal_sigsegv();
+		}
+	}
+}
+#endif /* __aarch64__ */
+
+
 void userspace(struct uml_pt_regs *regs, unsigned long *aux_fp_regs)
 {
 	int err, status, op, pid = userspace_pid[0];
@@ -399,7 +442,11 @@
 		}
 
 		regs->is_user = 1;
+		#ifdef __aarch64__
+		if (save_registers(pid, regs)) {
+		#else
 		if (ptrace(PTRACE_GETREGS, pid, 0, regs->gp)) {
+		#endif
 			printk(UM_KERN_ERR "%s - PTRACE_GETREGS failed, errno = %d\n",
 			       __func__, errno);
 			fatal_sigsegv();
@@ -411,6 +458,9 @@
 			fatal_sigsegv();
 		}
 
+		#ifdef __aarch64__
+		unsigned long arm64_pre_x8 = regs->gp[8];
+		#endif
 		UPT_SYSCALL_NR(regs) = -1; /* Assume: It's not a syscall */
 
 		if (WIFSTOPPED(status)) {
@@ -442,7 +492,33 @@
 				else handle_segv(pid, regs, aux_fp_regs);
 				break;
 			case SIGTRAP + 0x80:
+#ifdef __aarch64__
+				if (sysemu_supported) {
+					handle_trap(pid, regs);
+				} else if (!arm64_at_entry) {
+					arm64_at_entry = true;
+					arm64_saved_nr      = arm64_pre_x8;
+					arm64_saved_args[0] = regs->gp[0];
+					arm64_saved_args[1] = regs->gp[1];
+					arm64_saved_args[2] = regs->gp[2];
+					arm64_saved_args[3] = regs->gp[3];
+					arm64_saved_args[4] = regs->gp[4];
+					arm64_saved_args[5] = regs->gp[5];
+					arm64_neutralize_syscall(pid);
+				} else {
+					arm64_at_entry = false;
+					UPT_SYSCALL_NR(regs) = arm64_saved_nr;
+					regs->gp[0] = arm64_saved_args[0];
+					regs->gp[1] = arm64_saved_args[1];
+					regs->gp[2] = arm64_saved_args[2];
+					regs->gp[3] = arm64_saved_args[3];
+					regs->gp[4] = arm64_saved_args[4];
+					regs->gp[5] = arm64_saved_args[5];
+					handle_trap(pid, regs);
+				}
+#else
 				handle_trap(pid, regs);
+#endif
 				break;
 			case SIGTRAP:
 				relay_signal(SIGTRAP, (struct siginfo *)&si, regs);
