Subject: [PATCH] um: skas/process.c: arm64 ptrace compatibility via Rust externs

Wire in arm64 Rust symbols (arch/arm64/um/os-Linux/rust/):
  save_registers()         — PTRACE_GETREGSET via NT_PRSTATUS
  restore_registers()      — PTRACE_SETREGSET via NT_PRSTATUS
  arm64_neutralize_syscall() — PTRACE_SET_SYSCALL with PTRACE_SETREGSET fallback

arm64 does not have PTRACE_GETREGS/SETREGS/SYSEMU. Guards:
  - PTRACE_SYSCALL two-stop instead of PTRACE_SYSEMU
  - save_registers/restore_registers instead of PTRACE_GETREGS/SETREGS
  - Two-stop syscall interception: entry stop saves args + neutralizes,
    exit stop restores NR+args and calls handle_trap()

--- a/arch/um/os-Linux/skas/process.c
+++ b/arch/um/os-Linux/skas/process.c
@@ -21,6 +21,18 @@
 #include <ptrace_user.h>
 #include <registers.h>
 #include <skas.h>
+
+#ifdef __aarch64__
+/* arm64 register access and syscall neutralization — Rust static lib */
+#include <sys/uio.h>
+extern int save_registers(int pid, struct uml_pt_regs *regs);
+extern int restore_registers(int pid, struct uml_pt_regs *regs);
+extern void arm64_neutralize_syscall(int pid);
+extern int sysemu_supported;
+static bool arm64_at_entry;
+static unsigned long arm64_saved_nr;
+static unsigned long arm64_saved_args[6];
+#endif
 #include <sysdep/stub.h>
 #include <linux/threads.h>
 #include <timetravel.h>
@@ -84,8 +96,16 @@
 	unsigned long regs[MAX_REG_NR];
 	int i;
 
+	#ifdef __aarch64__
+	{
+		struct iovec iov = { regs, MAX_REG_NR * sizeof(unsigned long) };
+		if (ptrace(PTRACE_GETREGSET, pid, (void *)(long)NT_PRSTATUS, &iov) < 0)
+			return -errno;
+	}
+	#else
 	if (ptrace(PTRACE_GETREGS, pid, 0, regs) < 0)
 		return -errno;
+	#endif
 
 	printk(UM_KERN_ERR "Stub registers -\n");
 	for (i = 0; i < ARRAY_SIZE(regs); i++) {
@@ -368,11 +388,19 @@
 		 * fail.  In this case, there is nothing to do but
 		 * just kill the process.
 		 */
+		#ifdef __aarch64__
+		if (restore_registers(pid, regs)) {
+			printk(UM_KERN_ERR "%s - restore_registers failed, errno = %d\n",
+			       __func__, errno);
+			fatal_sigsegv();
+		}
+		#else
 		if (ptrace(PTRACE_SETREGS, pid, 0, regs->gp)) {
 			printk(UM_KERN_ERR "%s - ptrace set regs failed, errno = %d\n",
 			       __func__, errno);
 			fatal_sigsegv();
 		}
+		#endif
 
 		if (put_fp_registers(pid, regs->fp)) {
 			printk(UM_KERN_ERR "%s - ptrace set fp regs failed, errno = %d\n",
@@ -380,10 +408,14 @@
 			fatal_sigsegv();
 		}
 
+		#ifdef __aarch64__
+		op = PTRACE_SYSCALL;
+		#else
 		if (singlestepping())
 			op = PTRACE_SYSEMU_SINGLESTEP;
 		else
 			op = PTRACE_SYSEMU;
+		#endif
 
 		if (ptrace(op, pid, 0, 0)) {
 			printk(UM_KERN_ERR "%s - ptrace continue failed, op = %d, errno = %d\n",
@@ -399,11 +431,19 @@
 		}
 
 		regs->is_user = 1;
+		#ifdef __aarch64__
+		if (save_registers(pid, regs)) {
+			printk(UM_KERN_ERR "%s - save_registers failed, errno = %d\n",
+			       __func__, errno);
+			fatal_sigsegv();
+		}
+		#else
 		if (ptrace(PTRACE_GETREGS, pid, 0, regs->gp)) {
 			printk(UM_KERN_ERR "%s - PTRACE_GETREGS failed, errno = %d\n",
 			       __func__, errno);
 			fatal_sigsegv();
 		}
+		#endif
 
 		if (get_fp_registers(pid, regs->fp)) {
 			printk(UM_KERN_ERR "%s -  get_fp_registers failed, errno = %d\n",
@@ -411,6 +451,9 @@
 			fatal_sigsegv();
 		}
 
+		#ifdef __aarch64__
+		unsigned long arm64_pre_x8 = regs->gp[8];
+		#endif
 		UPT_SYSCALL_NR(regs) = -1; /* Assume: It's not a syscall */
 
 		if (WIFSTOPPED(status)) {
@@ -442,7 +485,33 @@
 				else handle_segv(pid, regs, aux_fp_regs);
 				break;
 			case SIGTRAP + 0x80:
+#ifdef __aarch64__
+				if (sysemu_supported) {
+					handle_trap(pid, regs);
+				} else if (!arm64_at_entry) {
+					arm64_at_entry = true;
+					arm64_saved_nr      = arm64_pre_x8;
+					arm64_saved_args[0] = regs->gp[0];
+					arm64_saved_args[1] = regs->gp[1];
+					arm64_saved_args[2] = regs->gp[2];
+					arm64_saved_args[3] = regs->gp[3];
+					arm64_saved_args[4] = regs->gp[4];
+					arm64_saved_args[5] = regs->gp[5];
+					arm64_neutralize_syscall(pid);
+				} else {
+					arm64_at_entry = false;
+					UPT_SYSCALL_NR(regs) = arm64_saved_nr;
+					regs->gp[0] = arm64_saved_args[0];
+					regs->gp[1] = arm64_saved_args[1];
+					regs->gp[2] = arm64_saved_args[2];
+					regs->gp[3] = arm64_saved_args[3];
+					regs->gp[4] = arm64_saved_args[4];
+					regs->gp[5] = arm64_saved_args[5];
+					handle_trap(pid, regs);
+				}
+#else
 				handle_trap(pid, regs);
+#endif
 				break;
 			case SIGTRAP:
 				relay_signal(SIGTRAP, (struct siginfo *)&si, regs);
