Subject: [PATCH] um/os-Linux/start_up.c: arm64 ptrace check via Rust extern

arm64 ptrace check and prctl setup are implemented in Rust:
  arch/arm64/um/os-Linux/rust/src/ptrace.rs  -> arm64_check_ptrace()
  arch/arm64/um/os-Linux/rust/src/prctl.rs   -> arch_prctl_defaults()

This patch wires them in via extern declarations and adds the arm64
early-return path in check_ptrace() and arch_prctl_defaults() call
in os_early_checks().

Removes the large C implementation that was previously inlined here.

--- a/arch/um/os-Linux/start_up.c
+++ b/arch/um/os-Linux/start_up.c
@@ -17,7 +17,9 @@
 #include <sys/wait.h>
 #include <sys/time.h>
 #include <sys/resource.h>
+#ifdef CONFIG_X86
 #include <asm/ldt.h>
+#endif
 #include <asm/unistd.h>
 #include <init.h>
 #include <os.h>
@@ -28,6 +30,14 @@
 #include <skas.h>
 #include "internal.h"
 
+/* arm64: ptrace check and prctl functions are in Rust (arch/arm64/um/os-Linux/rust/) */
+#ifdef __aarch64__
+extern void arm64_check_ptrace(void);
+extern void arch_prctl_defaults(void);
+#endif
+
+int sysemu_supported = 0;
+
 static void ptrace_child(void)
 {
 	int ret;
@@ -187,6 +197,11 @@
 static void __init check_ptrace(void)
 {
 	int pid, syscall, n, status;
+#ifdef __aarch64__
+	/* arm64 ptrace check is in Rust — arch/arm64/um/os-Linux/rust/src/ptrace.rs */
+	arm64_check_ptrace();
+	return;
+#endif
 
 	os_info("Checking that ptrace can change system call numbers...");
 	pid = start_ptraced_child();
@@ -283,6 +298,9 @@
 {
 	int pid;
 
+#ifdef __aarch64__
+	arch_prctl_defaults();
+#endif
 	/* Print out the core dump limits early */
 	check_coredump_limit();
 
